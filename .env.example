# Copy this file to .env and adjust as needed. Do NOT commit .env.
# Default values below work out of the box.

# Paths (relative to project root)
DATA_DIR=data
MODELS_DIR=models
INDEXES_DIR=indexes

# Sentence embeddings — MiniLM-L6-v2 is small, fast, and the standard baseline
SBERT_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local LLM (Ollama) for the natural-language rationale
# Default is qwen2.5:7b — smaller install, strong JSON adherence.
# Alternative: llama3.1:8b — matches the dissertation's baseline text.
# Pull the chosen model once with `ollama pull <model>` before first use.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Deterministic reproducibility across data generation + training
SEED=42
